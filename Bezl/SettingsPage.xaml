<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Bezl.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">
    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            MaxWidth="1064"
            Margin="36,24,36,0"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Settings" />

        <ScrollView
            Grid.Row="1"
            Padding="36,0,36,0"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Border>
                <StackPanel MaxWidth="1064" Spacing="{StaticResource SettingsCardSpacing}">
                    <StackPanel.ChildrenTransitions>
                        <RepositionThemeTransition />
                    </StackPanel.ChildrenTransitions>

                    <!--  Capture defaults  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Capture defaults" />

                    <toolkit:SettingsCard Description="The border padding applied to new captures" Header="Default padding">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE9A6;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <NumberBox
                            Width="120"
                            Maximum="200"
                            Minimum="0"
                            SmallChange="1"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind DefaultPadding, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard Description="The corner rounding applied to new captures" Header="Default corner radius">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE71A;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <NumberBox
                            Width="120"
                            Maximum="100"
                            Minimum="0"
                            SmallChange="1"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind DefaultCornerRadius, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <!--  About  -->
                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="About" />

                    <toolkit:SettingsExpander
                        Margin="0,0,0,36"
                        Description="© 2026 Niels Laute"
                        Header="Bezl">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <ImageIcon Source="Assets/AppIcon.ico" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="Version 1.0.0" />
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard
                                Click="GitHubCard_Click"
                                Header="Source code on GitHub"
                                IsClickEnabled="True">
                                <toolkit:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="&#xE8A7;" />
                                </toolkit:SettingsCard.ActionIcon>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                HorizontalContentAlignment="Left"
                                ContentAlignment="Vertical"
                                Header="License">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton Content="MIT License" NavigateUri="https://github.com/niels9001/Bezl/blob/main/LICENSE" />
                                </StackPanel>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                </StackPanel>
            </Border>
        </ScrollView>
    </Grid>
</Page>
