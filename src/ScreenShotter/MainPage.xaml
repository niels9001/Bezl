<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ScreenShotter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ScreenShotter"
    xmlns:models="using:ScreenShotter.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left Panel: Controls -->
        <ScrollViewer Grid.Column="0" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <!-- Capture Button -->
                <Button
                    Content="📸  Capture Window"
                    Command="{x:Bind ViewModel.CaptureWindowCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="40" />

                <!-- Screenshot Settings -->
                <TextBlock Text="Screenshot Settings" Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="Border Padding: " />
                        <Run Text="{x:Bind ViewModel.BorderPadding, Mode=OneWay}" />
                        <Run Text="px" />
                    </TextBlock>
                    <Slider
                        Value="{x:Bind ViewModel.BorderPadding, Mode=TwoWay}"
                        Minimum="0"
                        Maximum="200"
                        StepFrequency="1" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="Corner Radius: " />
                        <Run Text="{x:Bind ViewModel.CornerRadius, Mode=OneWay}" />
                        <Run Text="px" />
                    </TextBlock>
                    <Slider
                        Value="{x:Bind ViewModel.CornerRadius, Mode=TwoWay}"
                        Minimum="0"
                        Maximum="50"
                        StepFrequency="1" />
                </StackPanel>

                <!-- Gradient Settings -->
                <TextBlock Text="Gradient" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />

                <!-- Gradient Preview -->
                <Border CornerRadius="8" Height="100">
                    <Image Source="{x:Bind ViewModel.GradientPreview, Mode=OneWay}" Stretch="Fill" />
                </Border>

                <StackPanel Spacing="4">
                    <TextBlock Text="Start Color" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ColorPicker
                        Color="{x:Bind ViewModel.GradientStartColor, Mode=TwoWay}"
                        ColorSpectrumShape="Ring"
                        IsAlphaEnabled="False"
                        IsMoreButtonVisible="False"
                        IsHexInputVisible="True" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="End Color" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ColorPicker
                        Color="{x:Bind ViewModel.GradientEndColor, Mode=TwoWay}"
                        ColorSpectrumShape="Ring"
                        IsAlphaEnabled="False"
                        IsMoreButtonVisible="False"
                        IsHexInputVisible="True" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="Angle: " />
                        <Run Text="{x:Bind ViewModel.GradientAngle, Mode=OneWay}" />
                        <Run Text="°" />
                    </TextBlock>
                    <Slider
                        Value="{x:Bind ViewModel.GradientAngle, Mode=TwoWay}"
                        Minimum="0"
                        Maximum="360"
                        StepFrequency="1" />
                </StackPanel>

                <!-- Gradient Presets -->
                <TextBlock Text="Presets" Style="{StaticResource CaptionTextBlockStyle}" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.GradientPresets}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="130"
                            MinColumnSpacing="8"
                            MinRowSpacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:GradientDefinition">
                            <Button
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Content="{x:Bind Name}"
                                Tag="{x:Bind}"
                                Click="PresetButton_Click"
                                Padding="8,6" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Set as Wallpaper -->
                <Button
                    Content="🖼️  Set as Wallpaper"
                    Command="{x:Bind ViewModel.SetAsWallpaperCommand}"
                    HorizontalAlignment="Stretch"
                    Height="36"
                    Margin="0,8,0,0" />

            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel: Preview -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <Grid>
                    <!-- Placeholder when no capture -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibility}}">
                        <FontIcon Glyph="&#xE722;" FontSize="48" Opacity="0.3" />
                        <TextBlock
                            Text="Capture a window to see the preview"
                            Opacity="0.5"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0" />
                    </StackPanel>

                    <!-- Preview Image -->
                    <Image
                        Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Bar: Status + Export Buttons -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                VerticalAlignment="Center"
                Opacity="0.7"
                TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button
                    Content="📋  Copy to Clipboard"
                    Command="{x:Bind ViewModel.CopyToClipboardCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Height="36" />
                <Button
                    Content="💾  Save to File"
                    Command="{x:Bind ViewModel.SaveToFileCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Height="36" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
