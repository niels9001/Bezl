<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ScreenShotter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ScreenShotter"
    xmlns:models="using:ScreenShotter.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left Panel: Controls -->
        <ScrollViewer Grid.Column="0" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <!-- Capture Button -->
                <Button
                    Command="{x:Bind ViewModel.CaptureWindowCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="40">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE722;" FontSize="16" />
                        <TextBlock Text="Capture Window" />
                    </StackPanel>
                </Button>

                <!-- Wallpaper Gradients -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Wallpaper Gradients" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Click="AddGradient_Click" ToolTipService.ToolTip="Add new gradient" Padding="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                    </Button>
                </Grid>

                <!-- Gradient Grid -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Gradients}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="140"
                            MinColumnSpacing="8"
                            MinRowSpacing="8"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:GradientItem">
                            <Button
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Padding="0"
                                CornerRadius="8"
                                Tag="{x:Bind}"
                                Click="GradientCard_Click"
                                RightTapped="GradientCard_RightTapped">
                                <Button.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Edit" Click="EditGradient_Click" Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE70F;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Delete" Click="DeleteGradient_Click" Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="70" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- Gradient swatch -->
                                    <Border Grid.Row="0" CornerRadius="8,8,0,0">
                                        <Image Source="{x:Bind Preview, Mode=OneWay}" Stretch="Fill" />
                                    </Border>
                                    <!-- Name -->
                                    <TextBlock
                                        Grid.Row="1"
                                        Text="{x:Bind Name, Mode=OneWay}"
                                        HorizontalAlignment="Center"
                                        Padding="4,6"
                                        FontSize="12"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel: Preview + Border Slider -->
        <Grid Grid.Column="1" Grid.Row="0" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <Grid>
                    <!-- Placeholder when no capture -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibility}}">
                        <FontIcon Glyph="&#xE722;" FontSize="48" Opacity="0.3" />
                        <TextBlock
                            Text="Capture a window to see the preview"
                            Opacity="0.5"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0" />
                    </StackPanel>

                    <!-- Preview with corner radius handles overlay -->
                    <Grid
                        x:Name="PreviewContainer"
                        Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        PointerEntered="PreviewContainer_PointerEntered"
                        PointerExited="PreviewContainer_PointerExited">
                        <Image
                            x:Name="PreviewImage"
                            Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            SizeChanged="PreviewImage_SizeChanged" />
                        <!-- Corner radius handle overlay -->
                        <Canvas x:Name="HandleCanvas" IsHitTestVisible="True">
                            <!-- Top-left handle -->
                            <Ellipse x:Name="HandleTL" Width="16" Height="16"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     Stroke="White" StrokeThickness="2"
                                     Opacity="0"
                                     PointerPressed="Handle_PointerPressed"
                                     PointerMoved="Handle_PointerMoved"
                                     PointerReleased="Handle_PointerReleased" />
                            <!-- Top-right handle -->
                            <Ellipse x:Name="HandleTR" Width="16" Height="16"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     Stroke="White" StrokeThickness="2"
                                     Opacity="0"
                                     PointerPressed="Handle_PointerPressed"
                                     PointerMoved="Handle_PointerMoved"
                                     PointerReleased="Handle_PointerReleased" />
                            <!-- Bottom-left handle -->
                            <Ellipse x:Name="HandleBL" Width="16" Height="16"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     Stroke="White" StrokeThickness="2"
                                     Opacity="0"
                                     PointerPressed="Handle_PointerPressed"
                                     PointerMoved="Handle_PointerMoved"
                                     PointerReleased="Handle_PointerReleased" />
                            <!-- Bottom-right handle -->
                            <Ellipse x:Name="HandleBR" Width="16" Height="16"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     Stroke="White" StrokeThickness="2"
                                     Opacity="0"
                                     PointerPressed="Handle_PointerPressed"
                                     PointerMoved="Handle_PointerMoved"
                                     PointerReleased="Handle_PointerReleased" />
                        </Canvas>
                        <!-- Drag interaction border (shown while dragging) -->
                        <Border x:Name="DragBorder"
                                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                BorderThickness="2" CornerRadius="4"
                                Opacity="0" IsHitTestVisible="False" />
                        <!-- Corner radius label (shown while dragging) -->
                        <Border x:Name="RadiusLabel"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                CornerRadius="4" Padding="8,4"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Opacity="0" IsHitTestVisible="False">
                            <TextBlock x:Name="RadiusLabelText" FontSize="13" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Border Padding Slider -->
            <StackPanel Grid.Row="1" Spacing="4"
                        Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                    <Run Text="Border Padding: " />
                    <Run Text="{x:Bind ViewModel.BorderPadding, Mode=OneWay}" />
                    <Run Text="px" />
                </TextBlock>
                <Slider
                    Value="{x:Bind ViewModel.BorderPadding, Mode=TwoWay}"
                    Minimum="0"
                    Maximum="200"
                    StepFrequency="1" />
            </StackPanel>
        </Grid>

        <!-- Bottom Bar: Export Buttons -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,16,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.CopyToClipboardCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                        <TextBlock Text="Copy to Clipboard" />
                    </StackPanel>
                </Button>
                <Button
                    Command="{x:Bind ViewModel.SaveToFileCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="14" />
                        <TextBlock Text="Save to File" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
