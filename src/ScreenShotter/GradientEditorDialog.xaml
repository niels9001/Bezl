<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="ScreenShotter.GradientEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Edit Gradient"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    PrimaryButtonText="Save"
    mc:Ignorable="d">

    <StackPanel MinWidth="400" Spacing="16">
        <!-- Gradient Preview -->
        <Border Height="120" CornerRadius="8">
            <Image x:Name="GradientPreviewImage" Stretch="Fill" />
        </Border>

        <!-- Name -->
        <TextBox
            x:Name="NameBox"
            Header="Name"
            PlaceholderText="Gradient name" />

        <!-- Color buttons row -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Start Color -->
            <DropDownButton x:Name="StartColorButton" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border x:Name="StartColorSwatch" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Start Color" VerticalAlignment="Center" />
                </StackPanel>
                <DropDownButton.Flyout>
                    <Flyout>
                        <ColorPicker
                            x:Name="StartColorPicker"
                            ColorChanged="OnColorOrAngleChanged"
                            ColorSpectrumShape="Ring"
                            IsAlphaEnabled="False"
                            IsHexInputVisible="True"
                            IsMoreButtonVisible="False" />
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- End Color -->
            <DropDownButton x:Name="EndColorButton" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border x:Name="EndColorSwatch" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="End Color" VerticalAlignment="Center" />
                </StackPanel>
                <DropDownButton.Flyout>
                    <Flyout>
                        <ColorPicker
                            x:Name="EndColorPicker"
                            ColorChanged="OnColorOrAngleChanged"
                            ColorSpectrumShape="Ring"
                            IsAlphaEnabled="False"
                            IsHexInputVisible="True"
                            IsMoreButtonVisible="False" />
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </Grid>

        <!-- Angle -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="AngleLabel" Style="{StaticResource CaptionTextBlockStyle}" Text="Angle: 135°" />
            <Slider
                x:Name="AngleSlider"
                Maximum="360"
                Minimum="0"
                StepFrequency="1"
                ValueChanged="OnColorOrAngleChanged"
                Value="135" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
