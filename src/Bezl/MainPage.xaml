<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Bezl.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Bezl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Bezl.Models"
    mc:Ignorable="d">

    <Grid
        Padding="24"
        ColumnSpacing="24"
        RowSpacing="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CaptureWindowCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE722;" />
                    <TextBlock Margin="0,-2,0,0" Text="Capture" />
                </StackPanel>
            </Button>
            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.CopyToClipboardCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Copy to clipboard">
                    <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.SaveToFileCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCapture, Mode=OneWay}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Save to file">
                    <FontIcon FontSize="14" Glyph="&#xE74E;" />
                </Button>
                <Button
                    Click="SettingsButton_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Settings">
                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  Left Panel: Controls  -->
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Wallpaper Gradients  -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="Wallpaper gradients" />
                    <Button
                        Grid.Column="1"
                        Padding="6"
                        Click="AddGradient_Click"
                        ToolTipService.ToolTip="Add new gradient">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                    </Button>
                </Grid>
                <TextBlock
                    Grid.Row="1"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Select one of the gradients below to set as a wallpaper"
                    TextWrapping="Wrap" />

                <!--  Gradient Grid (scrollable)  -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsRepeater Margin="0,12,0,0" ItemsSource="{x:Bind ViewModel.Gradients}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsStretch="Fill"
                                MinColumnSpacing="6"
                                MinItemWidth="90"
                                MinRowSpacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:GradientItem">
                                <Button
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Click="GradientCard_Click"
                                    CornerRadius="8"
                                    RightTapped="GradientCard_RightTapped"
                                    Tag="{x:Bind}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="EditGradient_Click"
                                                Tag="{x:Bind}"
                                                Text="Edit">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE70F;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem
                                                Click="DeleteGradient_Click"
                                                Tag="{x:Bind}"
                                                Text="Delete">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="50" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <!--  Gradient swatch  -->
                                        <Border Grid.Row="0" CornerRadius="6,6,0,0">
                                            <Image Source="{x:Bind Preview, Mode=OneWay}" Stretch="Fill" />
                                        </Border>
                                        <!--  Name  -->
                                        <TextBlock
                                            Grid.Row="1"
                                            Padding="2,4"
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Text="{x:Bind Name, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>

            <!--  Right Panel: Preview + Sliders  -->
            <Grid Grid.Column="1" ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <!--  Placeholder when no capture  -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibility}}">
                            <FontIcon
                                FontSize="48"
                                Glyph="&#xE722;"
                                Opacity="0.3" />
                            <TextBlock
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Opacity="0.5"
                                Text="Capture a window to see the preview" />
                        </StackPanel>

                        <!--  Preview image  -->
                        <Image
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}"
                            Stretch="Uniform"
                            Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Border>

                <!--  Corner Radius vertical slider  -->
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <FontIcon
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xF03F;"
                        ToolTipService.ToolTip="Corner radius" />
                    <Slider
                        Width="28"
                        Height="200"
                        IsDirectionReversed="True"
                        Maximum="50"
                        Minimum="0"
                        Orientation="Vertical"
                        StepFrequency="1"
                        Value="{x:Bind ViewModel.CornerRadius, Mode=TwoWay}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind ViewModel.CornerRadius, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <!--  Border Padding Slider  -->
                <Grid
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    ColumnSpacing="12"
                    Visibility="{x:Bind ViewModel.HasCapture, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE9A6;"
                        ToolTipService.ToolTip="Image padding" />
                    <Slider
                        Grid.Column="1"
                        Maximum="200"
                        Minimum="0"
                        StepFrequency="1"
                        Value="{x:Bind ViewModel.BorderPadding, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind ViewModel.BorderPadding, Mode=OneWay}" />
                        <Run Text="px" />
                    </TextBlock>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
