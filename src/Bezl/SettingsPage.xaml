<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Bezl.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" Margin="0,16,0,0" HorizontalAlignment="Left" Spacing="4">

                <!-- Defaults section -->
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Defaults" />

                <!-- Default Padding -->
                <controls:SettingsExpander
                    Header="Default padding"
                    Description="The border padding applied to new captures">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE9A6;" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Content>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind DefaultPadding, Mode=OneWay}" /><Run Text="px" />
                        </TextBlock>
                    </controls:SettingsExpander.Content>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="Padding">
                            <Slider
                                MinWidth="200"
                                Maximum="200"
                                Minimum="0"
                                StepFrequency="1"
                                Value="{x:Bind DefaultPadding, Mode=TwoWay}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- Default Corner Radius -->
                <controls:SettingsExpander
                    Header="Default corner radius"
                    Description="The corner rounding applied to new captures">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xF03F;" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Content>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind DefaultCornerRadius, Mode=OneWay}" /><Run Text="px" />
                        </TextBlock>
                    </controls:SettingsExpander.Content>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="Corner radius">
                            <Slider
                                MinWidth="200"
                                Maximum="50"
                                Minimum="0"
                                StepFrequency="1"
                                Value="{x:Bind DefaultCornerRadius, Mode=TwoWay}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- About section -->
                <TextBlock
                    Margin="0,24,0,4"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="About" />

                <controls:SettingsExpander
                    Header="Bezl"
                    Description="Version 1.0.0">
                    <controls:SettingsExpander.HeaderIcon>
                        <ImageIcon Source="Assets/AppIcon.ico" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard
                            Header="Beautiful screenshot borders made easy"
                            Description="Capture any window and frame it with customizable gradient borders and rounded corners." />
                        <controls:SettingsCard Header="Source code">
                            <HyperlinkButton
                                Content="GitHub"
                                NavigateUri="https://github.com/niels9001/Bezl" />
                        </controls:SettingsCard>
                        <controls:SettingsCard
                            Header="License"
                            Description="MIT — © 2026 Bezl Contributors" />
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
